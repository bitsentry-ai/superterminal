{
  "name": "@bitsentry-ce/i18n",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./backend": {
      "types": "./dist/backend.d.ts",
      "default": "./dist/backend.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "default": "./dist/hooks.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "default": "./dist/provider.js"
    },
    "./locales/*": "./dist/locales/*",
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "audit:integrity": "node ../../scripts/i18n/audit-locale-integrity.mjs",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/i18n/postbuild.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "i18next": "^24.2.2",
    "i18next-browser-languagedetector": "^8.0.4",
    "react-i18next": "^15.4.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "ts-morph": "^24.0.0",
    "typescript": "^5.9.3"
  }
}

{
  "name": "@bitsentry-ce/coding-agents",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@alcyone-labs/zod-to-json-schema": "^4.0.10",
    "@bitsentry-ce/components": "workspace:*",
    "@bitsentry-ce/core": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.138",
    "electron-log": "^5.4.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@bitsentry-ce/components": ["./src/index.ts"],
      "@bitsentry-ce/components/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "types/**/*.d.ts"]
}

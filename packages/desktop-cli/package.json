{
  "name": "@bitsentry-ce/desktop-cli",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli/*": {
      "types": "./dist/cli/*.d.ts",
      "default": "./dist/cli/*.js"
    },
    "./runtime/*": {
      "types": "./dist/runtime/*.d.ts",
      "default": "./dist/runtime/*.js"
    },
    "./packaging/*": {
      "types": "./dist/packaging/*.d.ts",
      "default": "./dist/packaging/*.js"
    },
    "./testing/*": {
      "types": "./dist/testing/*.d.ts",
      "default": "./dist/testing/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@bitsentry-ce/coding-agents": "workspace:*",
    "@bitsentry-ce/core": "workspace:*",
    "electron": "40.9.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "node-cron": "^4.2.1",
    "yaml": "^2.9.0"
  }
}

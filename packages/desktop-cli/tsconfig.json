{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@bitsentry-ce/core": ["../core/src/index.ts"],
      "@bitsentry-ce/core/*": ["../core/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
